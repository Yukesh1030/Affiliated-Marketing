				<div class="elementor-widget-container">
					<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
document.addEventListener("DOMContentLoaded", function() {
    // Function to update SVG icons based on aria-selected attribute
    function updateTabIcons() {
        const tabTitles = document.querySelectorAll('.e-n-tab-title');

        tabTitles.forEach(tab => {
            const isSelected = tab.getAttribute('aria-selected') === 'true';
            const icon = document.createElement('span');
            icon.classList.add('tab-icon');

            // Set the SVG based on the aria-selected attribute
            if (isSelected) {
                icon.innerHTML = '<img decoding="async" src="/wp-content/uploads/2025/01/unnamed-file-1.png"></img>'; // Plus SVG
            } else {
                icon.innerHTML = '<img decoding="async" src="/wp-content/uploads/2025/01/unnamed-file.png"></img>'; // Minus SVG
            }

            // Clear existing icons and append the new one
            const existingIcon = tab.querySelector('.tab-icon');
            if (existingIcon) {
                existingIcon.remove(); // Remove existing icon if any
            }

            // Create a flex container for text and icon
            const flexContainer = document.createElement('div');
            flexContainer.classList.add('flex-container');
            flexContainer.style.display = 'flex';
            flexContainer.style.justifyContent = 'space-between';
            flexContainer.style.alignItems = 'center';

            // Append text and icon to the flex container
            flexContainer.appendChild(tab.querySelector('.e-n-tab-title-text'));
            flexContainer.appendChild(icon);

            // Replace the tab content with the new flex container
            tab.innerHTML = ''; // Clear existing content
            tab.appendChild(flexContainer); // Add the new flex container
        });
    }

    // Initial icon setup
    updateTabIcons();

    // Event listener for tab click
    const tabTitles = document.querySelectorAll('.e-n-tab-title');
    tabTitles.forEach(tab => {
        tab.addEventListener('click', function() {
            // Update aria-selected attributes
            tabTitles.forEach(t => t.setAttribute('aria-selected', 'false'));
            tab.setAttribute('aria-selected', 'true');

            // Update icons
            updateTabIcons();
        });
    });
});
</script>				</div>
				</div>
					</div>
